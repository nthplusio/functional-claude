{
  "description": "project-manager hooks — detect repo on session start, switch GitHub credentials, validate Linear MCP, prompt session wrap-up on stop",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pm-session-start.js",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pm-session-end.js",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
