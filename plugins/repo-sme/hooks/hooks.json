{
  "description": "repo-sme hooks — refresh repo clones on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/repo-sme-session-start.js\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
